{
  "manifest_version": 3,
  "name": "PinBack Extension",
  "version": "0.1.0",
  "action": { "default_popup": "popup.html" },
  "icons": {
    "128": "icon.png"
  },
  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.ts"]
    }
  ],
  "host_permissions": ["<all_urls>"]
}
