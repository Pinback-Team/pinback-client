{
  "extends": "@pinback/typescript-config/react.json",
  "compilerOptions": {
    "typeRoots": ["node_modules/@types"],

    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@lib/*": ["./src/lib/*"]
    },
    "jsx": "react-jsx"
  },
  "include": [
    "src",
    ".storybook",
    ".storybook/*.ts",
    "turbo/generators/config.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
